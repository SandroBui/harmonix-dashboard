NEXT_PUBLIC_SAFE_ADDRESS=
NEXT_PUBLIC_SAFE_API_KEY=

# Google OAuth — get from console.cloud.google.com
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Comma-separated list of allowed Google emails
AUTH_ALLOWED_EMAILS=

# Set to true to enable Google OAuth authentication guard
GOOGLE_AUTH=true
